{
  "outline_panel": {
    "dock": "right"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_fallbacks": ["Source Han Sans"],
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 18,
  "current_line_highlight": "none",
  "features": {
    "inline_completion_provider": "none"
  },
  "file_scan_exclusions": ["**/.git", "**/.ruff_cache", "**/__pycache__"],
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "tabs": {
    "git_status": true
  },
  "toolbar": {
    "breadcrumbs": false,
    "selections_menu": false
  },
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "journal": {
    "hour_format": "hour24"
  },
  "languages": {
    "Python": {
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "language_servers": ["pyright", "ruff"]
    }
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace"
        }
      }
    }
  },
  "relative_line_numbers": true,
  "show_whitespaces": "none",
  "terminal": {
    "blinking": "on",
    "dock": "bottom",
    "font_fallbacks": ["Source Han Sans"],
    "toolbar": {
      "title": false
    }
  },
  "theme": "Ayu Dark",
  "ui_font_fallbacks": ["Source Han Sans"],
  "ui_font_size": 18,
  "vim_mode": true
}
